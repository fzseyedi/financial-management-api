@host = http://localhost:5182

### Create customer
POST {{host}}/api/customers
Content-Type: application/json

{
  "code": "CUST-200",
  "name": "Yellow Delta Trading",
  "email": "info@yellowdelta.com",
  "phone": "666-2000",
  "address": "Ankara"
}

### Get active customers only (page 1, 10 items per page)
GET {{host}}/api/customers

### Get active customers - first page (explicit pagination)
GET {{host}}/api/customers?pageNumber=1&pageSize=10

### Get active customers - second page
GET {{host}}/api/customers?pageNumber=2&pageSize=10

### Get active customers - with custom page size
GET {{host}}/api/customers?pageNumber=1&pageSize=20

### Get all customers including inactive (page 1)
GET {{host}}/api/customers?includeInactive=true

### Get all customers including inactive - page 2 with custom size
GET {{host}}/api/customers?includeInactive=true&pageNumber=2&pageSize=15

### Get customer by id
GET {{host}}/api/customers/1

### Update customer
PUT {{host}}/api/customers/1
Content-Type: application/json

{
  "code": "CUST-001",
  "name": "Acme Trading Updated",
  "email": "sales@acme.com",
  "phone": "111111",
  "address": "Istanbul, Turkey"
}

### Deactivate customer
PUT {{host}}/api/customers/1/deactivate

### Activate customer
PUT {{host}}/api/customers/1/activate

### Delete customer
DELETE {{host}}/api/customers/1004
