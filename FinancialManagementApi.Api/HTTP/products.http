@host = http://localhost:5182

### Create product
POST {{host}}/api/products
Content-Type: application/json

{
  "code": "PRD-005",
  "name": "Logitech mouse",
  "unitPrice": 125.00
}

### Get active products only (page 1, 10 items per page)
GET {{host}}/api/products

### Get active products - first page (explicit pagination)
GET {{host}}/api/products?pageNumber=1&pageSize=10

### Get active products - second page
GET {{host}}/api/products?pageNumber=2&pageSize=10

### Get active products - with custom page size
GET {{host}}/api/products?pageNumber=1&pageSize=20

### Get all products including inactive (page 1)
GET {{host}}/api/products?includeInactive=true

### Get all products including inactive - page 2 with custom size
GET {{host}}/api/products?includeInactive=true&pageNumber=2&pageSize=15

### Get product by id
GET {{host}}/api/products/1

### Update product
PUT {{host}}/api/products/1
Content-Type: application/json

{
  "code": "PRD-001",
  "name": "Office Chair Deluxe",
  "unitPrice": 175.00
}

### Deactivate product
PUT {{host}}/api/products/1/deactivate

### Activate product
PUT {{host}}/api/products/1/activate

### Delete product
DELETE {{host}}/api/products/1

### Delete product that doesn't exist
DELETE {{host}}/api/products/999

### Delete product with invoice items (will fail)
DELETE {{host}}/api/products/2
